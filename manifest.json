{
  "manifest_version": 3,
  "name": "YouTube Wave Drawer",
  "version": "1.2",
  "description": "YouTubeの動画再生中に音声波形をリアルタイムで描画するChrome拡張",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
